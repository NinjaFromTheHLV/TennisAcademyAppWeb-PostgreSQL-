@using TennisAcademyApp.ViewModels.Ball;
@model BallEditFormModel

@{
    var requestCulture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "en";
    var isBg = currentCulture == "bg";

    ViewData["Title"] = isBg ? "Редактирай топки" : "Edit Ball";
}

<link rel="stylesheet" href="~/css/shop-admin.css" asp-append-version="true" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">

            <div class="card admin-form-card">
                <div class="text-center mb-4">
                    <span class="badge bg-dark border border-secondary border-opacity-25 text-white-50 px-3 py-2 rounded-pill mb-2 tracking-wider small">
                        <i class="bi bi-pencil-square text-warning me-1"></i> INVENTORY EDIT
                    </span>
                    <h2 class="fw-bold text-light m-0">@(isBg ? "Редактирай топки" : "Edit Ball")</h2>
                </div>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Brand" class="form-label text-white-50 small fw-bold text-uppercase">@(isBg ? "Марка" : "Brand")</label>
                            <input asp-for="Brand" class="form-control admin-input" />
                            <span asp-validation-for="Brand" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label text-white-50 small fw-bold text-uppercase">@(isBg ? "Модел" : "Model")</label>
                            <input asp-for="Model" class="form-control admin-input" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label text-white-50 small fw-bold text-uppercase">@(isBg ? "Цена (в EUR)" : "Price (in EUR)")</label>
                            <input asp-for="Price" class="form-control admin-input" type="number" step="0.01" min="0" placeholder="0.00" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Quantity" class="form-label text-white-50 small fw-bold text-uppercase">@(isBg ? "Количество" : "Quantity")</label>
                            <input asp-for="Quantity" class="form-control admin-input" type="number" min="0" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ImageUrl" class="form-label text-white-50 small fw-bold text-uppercase">@(isBg ? "Линк към снимка" : "Image URL")</label>
                        <input asp-for="ImageUrl" class="form-control admin-input" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-8">
                            <button type="submit" class="btn btn-submit-neon w-100 py-3 d-flex align-items-center justify-content-center gap-2">
                                <i class="bi bi-check-lg fs-5"></i>
                                @(isBg ? "Запази промените" : "Save Changes")
                            </button>
                        </div>
                        <div class="col-md-4">
                            <a asp-action="Index" class="btn btn-cancel-outline w-100 py-3 d-flex align-items-center justify-content-center">
                                @(isBg ? "Отказ" : "Cancel")
                            </a>
                        </div>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}