@using TennisAcademyApp.ViewModels.Bag
@model BagDeleteViewModel

@{
    var requestCulture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "en";
    var isBg = currentCulture == "bg";

    ViewData["Title"] = isBg ? "Изтрий сак" : "Delete Bag";
}

<link rel="stylesheet" href="~/css/shop-admin.css" asp-append-version="true" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="card admin-form-card overflow-hidden p-0">
                <div class="row g-0 align-items-center">

                    <div class="col-md-5 text-center">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Brand" class="img-fluid rounded-start d-block w-100" style="object-fit: cover; min-height: 320px; max-height: 400px;" />
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/400x400?text=No+Image" alt="No image" class="img-fluid rounded-start d-block w-100" style="object-fit: cover; min-height: 320px; max-height: 400px;" />
                        }
                    </div>

                    <div class="col-md-7">
                        <div class="card-body p-4 p-lg-5">

                            <div class="mb-3">
                                <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill tracking-wider small fw-bold">
                                    <i class="bi bi-exclamation-octagon-fill me-1"></i> DANGER ZONE
                                </span>
                            </div>

                            <h3 class="fw-bold text-light mb-3">
                                @(isBg ? "Сигурни ли сте, че искате да изтриете този сак?" : "Are you sure you want to delete this bag?")
                            </h3>

                            <div class="mb-4 p-3 rounded-3 bg-black bg-opacity-20 border border-secondary border-opacity-10">
                                <span class="text-muted d-block small text-uppercase tracking-wider">@(isBg ? "Артикул" : "Product Item")</span>
                                <span class="fs-4 fw-bold text-white">@Model.Brand - @Model.Model</span>
                            </div>

                            <div class="d-flex gap-2 flex-wrap">
                                <form asp-action="Delete" method="post" class="m-0 flex-grow-1 flex-md-grow-0">
                                    <input type="hidden" asp-for="Id" />
                                    <button type="submit" class="btn btn-delete-danger-neon py-3 px-4 w-100 d-flex align-items-center justify-content-center gap-2">
                                        <i class="bi bi-trash3-fill fs-5"></i>
                                        @(isBg ? "Потвърди изтриването" : "Confirm Delete")
                                    </button>
                                </form>

                                <a asp-action="Index" class="btn btn-cancel-outline py-3 px-4 d-flex align-items-center justify-content-center flex-grow-1 flex-md-grow-0">
                                    @(isBg ? "Отказ" : "Cancel")
                                </a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>