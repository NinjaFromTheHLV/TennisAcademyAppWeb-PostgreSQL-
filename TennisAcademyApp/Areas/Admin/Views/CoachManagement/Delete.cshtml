@using TennisAcademyApp.ViewModels.Coach
@model DeleteCoachViewModel

@{
    var requestCulture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "en";
    var isBg = currentCulture == "bg";

    ViewData["Title"] = isBg ? "Изтрий треньор" : "Delete Coach";
}

<link rel="stylesheet" href="~/css/admin-coach.css" asp-append-version="true" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="card admin-delete-panel overflow-hidden">
                <div class="row g-0 align-items-center">

                    <div class="col-md-4 text-center">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded-start d-block w-100" style="object-fit: cover; max-height: 400px;" />
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/400x500?text=No+Image" alt="No image" class="img-fluid rounded-start d-block w-100" style="object-fit: cover; max-height: 400px;" />
                        }
                    </div>

                    <div class="col-md-8">
                        <div class="card-body p-4 p-lg-5">

                            <div class="mb-3">
                                <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill tracking-wider small fw-bold">
                                    <i class="bi bi-exclamation-octagon-fill me-1"></i> DANGER ZONE
                                </span>
                            </div>

                            <h3 class="fw-bold text-light mb-3">
                                @(isBg ? "Сигурни ли сте, че искате да изтриете този треньор?" : "Are you sure you want to delete this coach?")
                            </h3>

                            <div class="mb-4 p-3 rounded-3 bg-black bg-opacity-20 border border-secondary border-opacity-10">
                                <span class="text-muted d-block small text-uppercase tracking-wider">@(isBg ? "Име на треньора" : "Coach Name")</span>
                                <span class="fs-4 fw-bold text-white">@Model.Name</span>
                            </div>

                            <form asp-action="Delete" method="post" class="d-flex gap-2 flex-wrap">
                                @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="CoachId" />

                                <button type="submit" class="btn btn-delete-danger-neon py-3 px-4 d-flex align-items-center justify-content-center gap-2">
                                    <i class="bi bi-trash3-fill fs-5"></i>
                                    @(isBg ? "Потвърди изтриването" : "Confirm Delete")
                                </button>

                                <a asp-action="Index" class="btn btn-cancel-outline py-3 px-4 d-flex align-items-center justify-content-center">
                                    @(isBg ? "Отказ" : "Cancel")
                                </a>
                            </form>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>