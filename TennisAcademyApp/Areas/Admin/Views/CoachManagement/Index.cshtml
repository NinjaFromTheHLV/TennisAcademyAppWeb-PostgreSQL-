@using TennisAcademyApp.ViewModels.Coach
@model PaginatedCoachesViewModel

@{
    var requestCulture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "en";
    var isBg = currentCulture == "bg";

    ViewData["Title"] = isBg ? "Управление на треньори" : "Coach Management";
}

<link rel="stylesheet" href="~/css/admin-coach.css" asp-append-version="true" />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show text-center border-0" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show text-center border-0" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <span class="badge bg-dark border border-secondary border-opacity-25 text-white-50 px-3 py-2 rounded-pill mb-2 tracking-wider small">
                <i class="bi bi-shield-lock-fill text-warning me-1"></i> STAFF CONTROL
            </span>
            <h2 class="fw-bold text-light m-0">@(isBg ? "Управление на треньори" : "Coach Management")</h2>
        </div>
        <div>
            <a asp-action="Add" class="btn btn-add-coach-neon py-2.5 px-4 text-nowrap">
                <i class="bi bi-person-plus-fill me-2"></i>@(isBg ? "Добави Треньор" : "Add Coach")
            </a>
        </div>
    </div>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group admin-search-group">
            <span class="input-group-text search-icon-box"><i class="bi bi-search"></i></span>
            <input type="text" name="searchQuery" class="form-control coach-search-input" placeholder="@(isBg ? "Търси по име..." : "Search by name...")" value="@Model.SearchQuery" />
            <button type="submit" class="btn btn-search-submit px-4">@(isBg ? "Търси" : "Search")</button>
            <a asp-action="Index" class="btn btn-search-clear px-3">@(isBg ? "Изчисти" : "Clear")</a>
        </div>
    </form>

    <div class="row g-4">
        @foreach (var coach in Model.Coaches)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card coach-premium-card h-100">
                    <div class="ratio ratio-4x3 overflow-hidden image-container">
                        <img src="@Url.Content(coach.ImageUrl)" class="card-img-top coach-card-img" alt="@coach.CoachName" />
                        <div class="card-img-overlay d-flex align-items-start justify-content-end p-3">
                            <span class="badge age-badge px-2.5 py-1.5 rounded-2 fw-bold">
                                @coach.CoachAge @(isBg ? "г." : "y/o")
                            </span>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div class="mb-3">
                            <h5 class="coach-title-name m-0 text-truncate">@coach.CoachName</h5>
                            <span class="text-muted small text-uppercase tracking-wider">@(isBg ? "Професионален Треньор" : "Professional Coach")</span>
                        </div>

                        <div class="d-flex gap-2 w-100 mt-2">
                            <a asp-action="Edit" asp-route-id="@coach.CoachId" class="btn btn-outline-warning btn-sm w-50 py-2 fw-bold text-uppercase text-nowrap">
                                <i class="bi bi-pencil-square me-1"></i>@(isBg ? "Редактирай" : "Edit")
                            </a>
                            <a asp-action="Delete" asp-route-id="@coach.CoachId" class="btn btn-outline-danger btn-sm w-50 py-2 fw-bold text-uppercase text-nowrap">
                                <i class="bi bi-trash3-fill me-1"></i>@(isBg ? "Изтрий" : "Delete")
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="d-flex justify-content-center mt-5">
            <ul class="pagination coach-custom-pagination">
                @if (Model.PageNumber > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber - 1)" asp-route-searchQuery="@Model.SearchQuery">&laquo;</a>
                    </li>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchQuery="@Model.SearchQuery">@i</a>
                    </li>
                }
                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber + 1)" asp-route-searchQuery="@Model.SearchQuery">&raquo;</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>