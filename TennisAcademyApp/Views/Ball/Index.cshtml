@using TennisAcademyApp.ViewModels.Ball
@model IEnumerable<BallIndexViewModel>

@{
    var requestCulture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "en";
    var isBg = currentCulture == "bg";

    ViewData["Title"] = isBg ? "Магазин за топки" : "Balls Shop";
}

<link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show w-100 rounded-0 text-center mb-0" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show w-100 rounded-0 text-center mb-0" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container py-4">
    <h1 class="text-center display-5 fw-bold my-4 text-gradient">@(isBg ? "Магазин за тенис топки" : "Tennis Balls Shop")</h1>

    <div class="d-flex justify-content-center my-4 gap-3 navigation-pills">
        <a asp-controller="Racket" asp-action="Index" class="btn btn-shop d-flex align-items-center gap-2 px-4 py-2.5 rounded-3">
            <i class="bi bi-lightning-charge-fill"></i> @(isBg ? "Ракети" : "Rackets")
        </a>
        <a asp-controller="Ball" asp-action="Index" class="btn btn-shop active d-flex align-items-center gap-2 px-4 py-2.5 rounded-3">
            <i class="bi bi-record-circle-fill"></i> @(isBg ? "Топки" : "Balls")
        </a>
        <a asp-controller="Bag" asp-action="Index" class="btn btn-shop d-flex align-items-center gap-2 px-4 py-2.5 rounded-3">
            <i class="bi bi-backpack2-fill"></i> @(isBg ? "Чанти" : "Bags")
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-2">
        @foreach (var ball in Model)
        {
            var isLowStock = ball.Quantity > 0 && ball.Quantity <= 3;
            var isOutOfStock = ball.Quantity == 0;

            <div class="col">
                <div class="card h-100 shop-card border-0 shadow-lg position-relative @(isOutOfStock ? "racket-disabled" : "")">

                    <div class="position-absolute top-0 start-0 m-3 z-index-2">
                        @if (isOutOfStock)
                        {
                            <span class="badge bg-danger text-uppercase px-3 py-2 rounded-2 small shadow">@(isBg ? "Изчерпано" : "Out of Stock")</span>
                        }
                        else if (isLowStock)
                        {
                            <span class="badge bg-warning text-dark text-uppercase px-3 py-2 rounded-2 small fw-bold shadow animate-pulse">@(isBg ? "Последни бройки!" : "Last Items!")</span>
                        }
                    </div>

                    <div class="img-zoom-container rounded-top-4">
                        <img src="@ball.ImageUrl" class="card-img-top object-fit-cover" alt="Ball Image" style="height: 320px;" />
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <span class="text-muted small text-uppercase tracking-wider fw-semibold mb-1">@ball.Brand</span>
                        <h4 class="card-title text-light fw-bold mb-3">@ball.Model</h4>

                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <div>
                                <span class="text-muted d-block small">@(isBg ? "Цена" : "Price")</span>
                                <h3 class="text-accent fw-bold m-0">@ball.Price.ToString("C", new System.Globalization.CultureInfo("de-DE"))</h3>
                            </div>
                            <div class="text-end">
                                <span class="text-muted d-block small">@(isBg ? "Наличност" : "Stock")</span>
                                <span class="fw-semibold @(isLowStock ? "text-warning" : "text-success")">@ball.Quantity @(isBg ? "бр." : "pcs")</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 p-4 pt-0">
                        @if (!isOutOfStock)
                        {
                            <button type="button"
                                    class="btn btn-buy w-100 py-2.5 rounded-3"
                                    data-bs-toggle="modal"
                                    data-bs-target="#quantityModal"
                                    data-id="@ball.Id"
                                    data-title="@ball.Brand - @ball.Model"
                                    data-max="@ball.Quantity">
                                <i class="bi bi-cart-plus-fill me-2"></i>@(isBg ? "Купи" : "Add to Cart")
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary w-100 py-2.5 rounded-3 border-0" disabled>
                                <i class="bi bi-dash-circle me-2"></i>@(isBg ? "Няма в наличност" : "Unavailable")
                            </button>
                        }
                    </div>

                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="quantityModal" tabindex="-1" aria-labelledby="quantityModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border border-secondary border-opacity-25 rounded-4 shadow-lg overflow-hidden" style="background-color: var(--bg-card) !important;">

            <div class="modal-header border-bottom border-secondary border-opacity-10 p-4" style="background-color: var(--bg-card) !important;">
                <h5 class="modal-title fw-bold text-white" id="quantityModalLabel">@(isBg ? "Избор на количество" : "Select Quantity")</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-controller="BallCart" asp-action="AddBallToCart" method="post">
                <div class="modal-body p-4" style="background-color: var(--bg-card) !important;">

                    <p class="text-white-50 small mb-1" style="font-size: 0.85rem; letter-spacing: 0.5px;">@(isBg ? "ПРОДУКТ" : "PRODUCT")</p>
                    <h4 id="modal-product-title" class="text-accent fw-bold mb-4" style="color: var(--accent) !important;"></h4>

                    <input type="hidden" name="ballId" id="modal-product-id" />

                    <div class="form-group">
                        <label class="form-label text-white fw-medium mb-2">@(isBg ? "Количество:" : "Quantity:")</label>

                        <div class="input-group shop-input-group justify-content-center mx-auto" style="max-width: 200px; background-color: rgba(0, 0, 0, 0.3) !important;">
                            <input type="number" name="quantity" id="modal-quantity-input" class="form-control text-center custom-number-input fs-5 py-2 text-white" value="1" min="1" style="color: #ffffff !important; background: transparent !important;" />
                        </div>

                        <span id="modal-stock-info" class="text-white-50 small d-block text-center mt-3"></span>
                    </div>
                </div>

                <div class="modal-footer border-top border-secondary border-opacity-10 p-4" style="background-color: var(--bg-card) !important;">
                    <button type="button" class="btn btn-secondary px-4 py-2 rounded-3 border-0" data-bs-dismiss="modal">@(isBg ? "Отказ" : "Cancel")</button>
                    <button type="submit" class="btn btn-buy px-4 py-2 rounded-3">
                        <i class="bi bi-check-circle-fill me-2"></i>@(isBg ? "Потвърди" : "Confirm")
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const quantityModal = document.getElementById('quantityModal');

            if (quantityModal) {
                quantityModal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;

                    const productId = button.getAttribute('data-id');
                    const productTitle = button.getAttribute('data-title');
                    const maxQuantity = button.getAttribute('data-max');

                    const modalIdInput = quantityModal.querySelector('#modal-product-id');
                    const modalTitle = quantityModal.querySelector('#modal-product-title');
                    const modalQuantityInput = quantityModal.querySelector('#modal-quantity-input');
                    const modalStockInfo = quantityModal.querySelector('#modal-stock-info');

                    modalIdInput.value = productId;
                    modalTitle.textContent = productTitle;
                    modalQuantityInput.value = 1;
                    modalQuantityInput.setAttribute('max', maxQuantity);

                    const isBg = '@isBg' === 'True';
                    modalStockInfo.textContent = isBg
                        ? `Максимално налично количество: ${maxQuantity} бр.`
                        : `Maximum available stock: ${maxQuantity} pcs.`;
                });
            }
        });
    </script>
}