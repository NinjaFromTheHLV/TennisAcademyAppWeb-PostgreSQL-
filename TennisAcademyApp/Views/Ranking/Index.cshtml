@model IEnumerable<TennisAcademyApp.ViewModels.Ranking.UserRankingViewModel>
@{
    var requestCulture = ViewContext.HttpContext.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var isBg = (requestCulture?.RequestCulture.UICulture.Name ?? "en") == "bg";
    ViewData["Title"] = isBg ? "Ранглиста" : "Leaderboard";
    ViewData["ContentClass"] = "big-footer-margin";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-light"><i class="bi bi-fire text-danger me-2"></i>@(isBg ? "Ранглиста и Награди" : "Leaderboard & Rewards")</h2>
        <p class="text-muted">
            @(isBg ? "Печелете точки от активности и вземете до 20% отстъпка в магазина!" : "Earn points from activities and get up to 20% discount in the shop!")
        </p>
    </div>

    <div class="card shadow border-0 rounded-4 bg-dark text-light p-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr class="text-secondary border-secondary text-center">
                        <th style="width: 8%">#</th>
                        <th style="width: 32%" class="text-start">@(isBg ? "Играч" : "Player")</th>
                        <th style="width: 12%"><i class="bi bi-trophy text-primary"></i> @(isBg ? "Турнири" : "Tournaments")</th>
                        <th style="width: 12%"><i class="bi bi-calendar-check text-info"></i> @(isBg ? "Резервации" : "Reservations")</th>
                        <th style="width: 12%"><i class="bi bi-bag-check text-warning"></i> @(isBg ? "Артикули" : "Items")</th>
                        <th style="width: 12%">@(isBg ? "Точки" : "Points")</th>
                        <th style="width: 12%">@(isBg ? "Отстъпка" : "Discount")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var player in Model)
                    {
                        <tr class="border-secondary text-center">
                            <td class="fw-bold fs-5">
                                @if (player.Position == 1)
                                {
                                    <i class="bi bi-award-fill text-warning fs-4"></i>
                                }
                                else if (player.Position == 2)
                                {

                                    <i class="bi bi-award-fill text-light fs-4"></i>
                                }
                                else if (player.Position == 3)
                                {

                                    <i class="bi bi-award-fill text-danger fs-4"></i>
                                }
                                else
                                {

                                    <span>@player.Position</span>
                                }
                            </td>
                            <td class="fw-semibold text-success text-start">@player.FullName</td>
                            <td>@player.TournamentsCount</td>
                            <td>@player.ReservationsCount</td>
                            <td>@player.BoughtItemsCount</td>
                            <td><span class="fw-bold text-light">@player.TotalPoints pts</span></td>
                            <td>
                                @if (player.DiscountPercentage > 0)
                                {
                                    <span class="badge bg-danger px-2 py-2 rounded-3 text-light fw-bold fs-6">
                                        -@player.DiscountPercentage%
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>