@using static TennisAcademyApp.GCommon.Validations.ValidationConstants;
@using Microsoft.AspNetCore.Builder
@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Options

@inject IOptions<RequestLocalizationOptions> LocOptions

@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "en";
    var isBg = currentCulture == "bg";
}

<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TennisAcademy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TennisAcademyApp.styles.css" asp-append-version="true" />

    <style>
        /* Стилизация само за Инструкции прозореца */
        .glass-modal {
            background: rgba(18, 24, 38, 0.95) !important;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(13, 202, 240, 0.4) !important;
            border-radius: 20px;
            box-shadow: 0 0 30px rgba(13, 202, 240, 0.15), inset 0 0 15px rgba(13, 202, 240, 0.05) !important;
        }

            .glass-modal .modal-header {
                border-bottom: 1px solid rgba(13, 202, 240, 0.15);
            }

            .glass-modal .modal-footer {
                border-top: 1px solid rgba(13, 202, 240, 0.15);
            }

        .instruction-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            transition: all 0.3s ease;
        }

            .instruction-card:hover {
                border-color: rgba(13, 202, 240, 0.3);
                background: rgba(13, 202, 240, 0.03);
            }

        .glow-btn {
            box-shadow: 0 0 10px rgba(13, 202, 240, 0.3);
            transition: all 0.3s ease;
        }

            .glow-btn:hover {
                box-shadow: 0 0 20px rgba(13, 202, 240, 0.6);
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <nav id="sidebar" class="navbar-dark bg-card border-end d-flex flex-column p-3 collapsed">
        <div class="d-flex align-items-center justify-content-between mb-4">
            @if (User.IsInRole(Admin))
            {
                <a class="navbar-brand fw-bold" asp-area="Admin" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shield-lock-fill text-warning"></i> @(isBg ? "Админ Панел" : "Admin Dashboard")
                </a>
            }
            else
            {
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-trophy-fill text-primary"></i> TennisAcademy
                </a>
            }
        </div>

        <ul class="nav flex-column flex-grow-1 gap-2">
            <li class="nav-item">
                <a class="nav-link dropdown-toggle d-flex align-items-center justify-content-between"
                   data-bs-toggle="collapse"
                   data-bs-target="#coachSubmenu"
                   role="button"
                   aria-expanded="false">
                    <span><i class="bi bi-people-fill me-2"></i> @(isBg ? "Треньорски състав" : "Coaches")</span>
                </a>
                <ul class="collapse list-unstyled ps-3 mt-1 gap-1" id="coachSubmenu">
                    <li><a class="nav-link small" asp-area="" asp-controller="Coach" asp-action="Index">@(isBg ? "Нашите Треньори" : "Our Coaches")</a></li>
                    <li><a class="nav-link small" asp-area="" asp-controller="FavouriteCoach" asp-action="Favourite">@(isBg ? "Любими Треньори" : "My Favourite Coaches")</a></li>
                </ul>
            </li>

            @if (!User.IsInRole(Admin))
            {
                <li class="nav-item">
                    <a class="nav-link dropdown-toggle d-flex align-items-center justify-content-between"
                       data-bs-toggle="collapse"
                       data-bs-target="#reservationSubmenu"
                       role="button"
                       aria-expanded="false">
                        <span><i class="bi bi-calendar3 me-2"></i> @(isBg ? "Резервации" : "Reservations")</span>
                    </a>
                    <ul class="collapse list-unstyled ps-3 mt-1 gap-1" id="reservationSubmenu">
                        <li><a class="nav-link small" asp-area="" asp-controller="Reservation" asp-action="Index">@(isBg ? "Моите Резервации" : "My Reservations")</a></li>
                        <li><a class="nav-link small" asp-area="" asp-controller="Reservation" asp-action="Create">@(isBg ? "Резервирай корт" : "Reserve")</a></li>
                        <li><a class="nav-link small" asp-area="" asp-controller="Reservation" asp-action="ReservationHistory">@(isBg ? "История" : "History")</a></li>
                    </ul>
                </li>
            }

            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-controller="Racket" asp-action="Index">
                    <i class="bi bi-shop me-2"></i> @(isBg ? "Магазин" : "Shop")
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-light d-flex align-items-center gap-2" asp-area="" asp-controller="Tournament" asp-action="All">
                    <i class="bi bi-trophy text-warning fs-5"></i>
                    <span>@(isBg ? "Турнири" : "Tournaments")</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark" asp-area="" asp-controller="Ranking" asp-action="Index">
                    <i class="bi bi-trophy-fill text-warning me-1"></i>
                    @(isBg ? "Ранглиста" : "Leaderboard")
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Wheel" asp-action="Index">
                    <i class="bi bi-gift-fill text-danger me-1"></i>
                    @(isBg ? "Колело на късмета" : "Wheel of Fortune")
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link dropdown-toggle d-flex align-items-center justify-content-between"
                   data-bs-toggle="collapse"
                   data-bs-target="#cartSubmenu"
                   role="button"
                   aria-expanded="false">
                    <span><i class="bi bi-cart-fill me-2"></i> @(isBg ? "Количка" : "Cart")</span>
                </a>
                <ul class="collapse list-unstyled ps-3 mt-1 gap-1" id="cartSubmenu">
                    <li><a class="nav-link small" asp-controller="RacketCart" asp-action="Index">@(isBg ? "Ракети" : "Rackets")</a></li>
                    <li><a class="nav-link small" asp-controller="BallCart" asp-action="Index">@(isBg ? "Топки" : "Balls")</a></li>
                    <li><a class="nav-link small" asp-controller="BagCart" asp-action="Index">@(isBg ? "Сакове" : "Bags")</a></li>
                </ul>
            </li>
            @if (User.Identity.IsAuthenticated && User.IsInRole("Coach"))
            {
                <li class="nav-item">
                    <a class="nav-link text-white fw-bold" asp-controller="Schedule" asp-action="MySchedule">
                        <i class="bi bi-calendar-check me-1 text-accent"></i> @(isBg ? "Моят График" : "My Schedule")
                    </a>
                </li>
            }
            @if (User.IsInRole(Admin))
            {
                <li class="nav-item">
                    <a class="nav-link dropdown-toggle d-flex align-items-center justify-content-between"
                       data-bs-toggle="collapse"
                       data-bs-target="#adminSubmenu"
                       role="button"
                       aria-expanded="false">
                        <span><i class="bi bi-gear-fill me-2"></i> @(isBg ? "Управление" : "Manage")</span>
                    </a>
                    <ul class="collapse list-unstyled ps-3 mt-1 gap-1" id="adminSubmenu">
                        <li><a class="nav-link small" asp-area="Admin" asp-controller="UserManagement" asp-action="Index">@(isBg ? "Потребители" : "Users")</a></li>
                        <li><a class="nav-link small" asp-area="Admin" asp-controller="CoachManagement" asp-action="Index">@(isBg ? "Трен. профили" : "Coaches")</a></li>
                        <li><a class="nav-link small" asp-area="Admin" asp-controller="RacketManagement" asp-action="Index">@(isBg ? "Ракети каталог" : "Rackets")</a></li>
                        <li><a class="nav-link small" asp-area="Admin" asp-controller="BallManagement" asp-action="Index">@(isBg ? "Топки каталог" : "Balls")</a></li>
                        <li><a class="nav-link small" asp-area="Admin" asp-controller="BagManagement" asp-action="Index">@(isBg ? "Сакове каталог" : "Bags")</a></li>
                        <li><a class="nav-link small" asp-area="Admin" asp-controller="Reports" asp-action="Index">📊 @(isBg ? "Бизнес Справки" : "Reports")</a></li>
                    </ul>
                </li>
            }
        </ul>
    </nav>

    <script>
        if (sessionStorage.getItem('sidebarCollapsed') === 'false') {
            document.getElementById('sidebar').classList.remove('collapsed');
        }
    </script>

    <div id="content-wrapper">
        <header class="navbar navbar-expand navbar-light bg-card border-bottom p-3">
            <div class="container-fluid p-0">
                <button type="button" id="sidebarToggle" class="btn btn-outline-primary border-0 me-3">
                    <i class="bi bi-list fs-4"></i>
                </button>

                <div class="ms-auto d-flex align-items-center gap-3">

                    <button type="button" class="btn btn-outline-info btn-sm d-flex align-items-center gap-2 glow-btn" data-bs-toggle="modal" data-bs-target="#instructionsModal">
                        <i class="bi bi-lightbulb-fill text-warning"></i>
                        <span class="fw-bold">@(isBg ? "Инструкции" : "Instructions")</span>
                    </button>

                    <div class="dropdown">
                        <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" id="langDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            🌐 @(isBg ? "Български" : "English")
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="langDropdown">
                            @{
                                var returnUrl = string.IsNullOrEmpty(Context.Request.Path) ? "/" : $"{Context.Request.Path}{Context.Request.QueryString}";
                            }
                            <li>
                                <form asp-area="" asp-controller="Language" asp-action="SetLanguage" asp-route-returnUrl="@returnUrl" asp-route-culture="bg" method="post">
                                    <button type="submit" class="dropdown-item @(isBg ? "active" : "")">Български (BG)</button>
                                </form>
                            </li>
                            <li>
                                <form asp-area="" asp-controller="Language" asp-action="SetLanguage" asp-route-returnUrl="@returnUrl" asp-route-culture="en" method="post">
                                    <button type="submit" class="dropdown-item @(!isBg ? "active" : "")">English (EN)</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </header>

        <div class="container-fluid p-4 flex-grow-1 @ViewData["ContentClass"]">
            <main role="main">
                @RenderBody()
            </main>
        </div>

        <div class="modal fade" id="instructionsModal" tabindex="-1" aria-labelledby="instructionsModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content glass-modal text-light">
                    <div class="modal-header">
                        <h5 class="modal-title text-info fw-bold" id="instructionsModalLabel">
                            <i class="bi bi-rocket-takeoff-fill text-warning me-2"></i> Welcome to my project! 🎾✨
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">

                        <p class="text-secondary mb-4 small">
                            @(isBg ? "Здравейте! Ето малко полезна информация за тестване на приложението:" : "Hello! Here is some useful information for testing the app:")
                        </p>

                        <div class="instruction-card p-3 mb-3">
                            <h6 class="text-warning fw-bold mb-3"><i class="bi bi-shield-lock me-2"></i>@(isBg ? "Администратор" : "Administrator")</h6>
                            <div class="d-flex justify-content-between border-bottom border-secondary border-opacity-25 pb-2 mb-2">
                                <span class="text-secondary small">Email:</span>
                                <span class="fw-medium text-white">admin@abv.bg</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-secondary small">Password:</span>
                                <span class="fw-medium text-white">admin123!</span>
                            </div>
                        </div>

                        <div class="instruction-card p-3">
                            <h6 class="text-info fw-bold mb-2"><i class="bi bi-person-badge me-2"></i>@(isBg ? "Треньорски профили" : "Coach Profiles")</h6>
                            <p class="small text-secondary mb-3">
                                @(isBg ? "Акаунтите се генерират автоматично по следната логика:" : "Accounts are automatically generated using this logic:")
                            </p>
                            <div class="d-flex justify-content-between border-bottom border-secondary border-opacity-25 pb-2 mb-2">
                                <span class="text-secondary small">Email:</span>
                                <span class="fw-medium text-info">@(isBg ? "[име].[фамилия]" : "[firstname].[lastname]")@tennis.com</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-secondary small">Password:</span>
                                <span class="fw-medium text-white">coach123!</span>
                            </div>
                        </div>

                    </div>
                    <div class="modal-footer p-3">
                        <button type="button" class="btn btn-outline-info w-100" data-bs-dismiss="modal">
                            @(isBg ? "Разбрах, нека тестваме!" : "Got it, let's test!")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <footer class="mt-auto bg-dark border-top border-secondary position-relative overflow-hidden footer-master">
            <div class="footer-ambient-glow"></div>
            <div class="container py-5 position-relative z-1">
                <div class="row g-4 align-items-center">
                    <div class="col-lg-7 text-center text-lg-start">
                        <h3 class="fw-bold text-white mb-3">
                            <i class="bi bi-trophy-fill text-warning me-2 d-inline-block shadow-pulse"></i>TennisAcademy
                        </h3>
                        <p class="text-secondary mb-4 pe-lg-5">
                            @(isBg ? "Преоткрий играта. Усъвършенствай удара си. Резервирай своя корт само с няколко клика." : "Rediscover the game. Perfect your swing. Reserve your court with just a few clicks.")
                        </p>
                        <div class="row g-4 mb-4 text-start justify-content-center justify-content-lg-start">
                            <div class="col-sm-6 col-md-5">
                                <h6 class="text-uppercase tracking-wide mb-3 neon-text-blue"><i class="bi bi-clock me-2"></i>@(isBg ? "Работно време" : "Working Hours")</h6>
                                <ul class="list-unstyled text-secondary small">
                                    <li class="d-flex justify-content-between border-bottom border-secondary pb-1 mb-2">
                                        <span>@(isBg ? "Пон - Пет:" : "Mon - Fri:")</span> <span class="text-white">08:00 - 20:00</span>
                                    </li>
                                    <li class="d-flex justify-content-between">
                                        <span>@(isBg ? "Съб - Нед:" : "Sat - Sun:")</span> <span class="text-danger fw-bold">@(isBg ? "Почивни дни" : "Closed")</span>
                                    </li>
                                </ul>
                            </div>
                            <div class="col-sm-6 col-md-5">
                                <h6 class="text-uppercase tracking-wide mb-3 neon-text-blue"><i class="bi bi-geo-alt me-2"></i>@(isBg ? "Контакти" : "Contacts")</h6>
                                <ul class="list-unstyled text-secondary small">
                                    <li class="mb-2"><i class="bi bi-pin-map text-white me-2"></i>@(isBg ? "София, Студентски град" : "Sofia, Studentski grad")</li>
                                    <li class="mb-3"><i class="bi bi-telephone text-white me-2"></i>+359 888 123 456</li>
                                    <li>
                                        <div class="live-status-badge">
                                            <span class="pulsing-dot"></span> @(isBg ? "Кортовете са отворени" : "Courts are open")
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <div class="social-links d-flex gap-3 justify-content-center justify-content-lg-start mt-2">
                            <a href="https://github.com/NinjaFromTheHLV" target="_blank" class="social-btn github text-white fs-5" title="GitHub Repository">
                                <i class="bi bi-github"></i>
                            </a>
                            <a href="https://www.linkedin.com/in/yordan-pavlov-a78555400/" target="_blank" class="social-btn linkedin text-info fs-5" title="LinkedIn Profile">
                                <i class="bi bi-linkedin"></i>
                            </a>

                            <a href="javascript:void(0);" class="social-btn instagram fs-5"><i class="bi bi-instagram"></i></a>
                            <a href="javascript:void(0);" class="social-btn facebook fs-5"><i class="bi bi-facebook"></i></a>
                            <a href="javascript:void(0);" class="social-btn youtube fs-5"><i class="bi bi-youtube"></i></a>
                            <a href="javascript:void(0);" class="social-btn tiktok fs-5"><i class="bi bi-tiktok"></i></a>
                        </div>
                    </div>
                    <div class="col-lg-5 mt-5 mt-lg-0 border-start border-secondary d-flex justify-content-center align-items-center">
                        <div class="iso-arena-wrapper bg-transparent border-0">
                            <div class="iso-arena">
                                <div class="iso-court">
                                    <div class="court-lines"></div>
                                    <div class="net-3d"></div>
                                    <div class="ball-shadow"></div>
                                    <div class="ball-3d"></div>
                                    <div class="stickman opponent">
                                        <div class="head"></div><div class="torso"></div>
                                        <div class="arm arm-left"></div>
                                        <div class="arm arm-right"><div class="racket"></div></div>
                                        <div class="leg leg-left"></div><div class="leg leg-right"></div>
                                    </div>
                                    <div class="stickman player-main">
                                        <div class="head text-primary-glow"></div><div class="torso"></div>
                                        <div class="arm arm-left"></div>
                                        <div class="arm arm-right"><div class="racket"></div></div>
                                        <div class="leg leg-left"></div><div class="leg leg-right"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row mt-5 pt-4 border-top border-secondary text-center">
                    <div class="col-12 py-2">
                        <small class="text-secondary tracking-wide d-block">
                            &copy; @DateTime.Now.Year - TENNIS ACADEMY APP
                            <span class="mx-2 opacity-50">|</span>
                            ENDLESS RALLY EDITION
                        </small>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sidebar = document.getElementById('sidebar');
            const sidebarToggle = document.getElementById('sidebarToggle');

            sidebarToggle.addEventListener('click', function () {
                sidebar.classList.toggle('collapsed');
                sessionStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>