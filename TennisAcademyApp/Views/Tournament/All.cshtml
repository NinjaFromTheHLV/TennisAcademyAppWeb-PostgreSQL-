@model TennisAcademyApp.ViewModels.Tournament.TournamentQueryViewModel
@using Microsoft.AspNetCore.Identity
@using TennisAcademyApp.Data.Models
@inject UserManager<ApplicationUser> UserManager
@{
    var requestCulture = ViewContext.HttpContext.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var isBg = (requestCulture?.RequestCulture.UICulture.Name ?? "en") == "bg";
    ViewData["Title"] = isBg ? "Турнири" : "Tournaments";
    var currentUserId = UserManager.GetUserId(User);
}

<div class="container mt-5">
    <h2 class="text-center fw-bold mb-4 text-light">@(isBg ? "Предстоящи Турнири" : "Upcoming Tournaments")</h2>

    <form method="get" asp-action="All" class="row g-3 mb-5 p-4 bg-dark rounded-4 shadow">
        <div class="col-md-5">
            <div class="form-floating">
                <input asp-for="SearchTerm" class="form-control bg-secondary text-light border-0 rounded-3" placeholder="Search..." />
                <label asp-for="SearchTerm" class="text-muted">@(isBg ? "Търси по име или описание..." : "Search by name or description...")</label>
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-floating">
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select bg-secondary text-light border-0 rounded-3">
                    <option value="">@(isBg ? "Всички Категории" : "All Categories")</option>
                </select>
                <label asp-for="CategoryId" class="text-muted">@(isBg ? "Категория" : "Category")</label>
            </div>
        </div>
        <div class="col-md-3 d-flex align-items-center justify-content-end gap-2">
            <button type="submit" class="btn btn-success h-100 w-100 rounded-3 fw-bold py-3">
                <i class="bi bi-search me-2"></i>@(isBg ? "Филтрирай" : "Filter")
            </button>
            <a asp-action="All" class="btn btn-outline-secondary h-100 w-100 rounded-3 py-3 text-light">
                @(isBg ? "Изчисти" : "Clear")
            </a>
        </div>
    </form>

    <div class="row">
        @if (!Model.Tournaments.Any())
        {
            <div class="text-center my-5">
                <h4 class="text-muted">@(isBg ? "Няма намерени турнири по избраните критерии." : "No tournaments found matching the criteria.")</h4>
            </div>
        }
        else
        {
            @foreach (var tournament in Model.Tournaments)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow border-0 rounded-4 bg-dark text-light position-relative">

                        @if (currentUserId != null && tournament.CurrentParticipantsCount > 0 &&
                                        Context.RequestServices.GetRequiredService<TennisAcademyApp.Data.TennisAcademyDbContext>()
                                        .TournamentsUsers.Any(tu => tu.TournamentId == tournament.Id && tu.UserId == currentUserId))
                        {
                            <div class="position-absolute top-0 end-0 mt-3 me-3">
                                <span class="badge bg-success rounded-pill px-3 py-2 d-flex align-items-center gap-1 shadow-sm">
                                    <i class="bi bi-check-circle-fill"></i>
                                    @(isBg ? "Записан" : "Joined")
                                </span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <div class="pe-5">
                                <span class="badge bg-primary align-self-start mb-2">
                                    @(isBg? tournament.CategoryNameBg: tournament.CategoryName)
                                </span>
                                <h4 class="card-title fw-semibold">@(isBg? tournament.TitleBg: tournament.Title)</h4>
                            </div>

                            <p class="card-text text-muted small mb-1 mt-2">
                                <i class="bi bi-calendar-event me-2"></i>@tournament.StartDate.ToString("dd.MM.yyyy") - @tournament.EndDate.ToString("dd.MM.yyyy")
                            </p>
                            <p class="card-text fw-bold text-success mb-3">
                                @(isBg ? "Такса:" : "Fee:") €@tournament.EntryFee.ToString("F2")
                            </p>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between text-muted small mb-3">
                                    <span>@(isBg ? "Места:" : "Slots:")</span>
                                    <span>@tournament.CurrentParticipantsCount / @tournament.MaxParticipants</span>
                                </div>
                                <a asp-action="Details" asp-route-id="@tournament.Id" class="btn btn-outline-success w-100 rounded-3">
                                    @(isBg ? "Детайли" : "Details")
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link btn btn-outline-success me-1 rounded-3 @(Model.CurrentPage == 1 ? "disabled" : "")"
                       asp-action="All"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-page="@(Model.CurrentPage - 1)">
                        &laquo; @(isBg ? "Предишна" : "Previous")
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item mx-1">
                        <a class="page-link rounded-3 @(i == Model.CurrentPage ? "bg-success text-light border-success" : "bg-dark text-success border-secondary")"
                           asp-action="All"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link btn btn-outline-success ms-1 rounded-3 @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")"
                       asp-action="All"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-page="@(Model.CurrentPage + 1)">
                        @(isBg ? "Следваща" : "Next") &raquo;
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>