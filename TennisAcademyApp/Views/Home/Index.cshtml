@using TennisAcademyApp.Services.Core.Contracts
@inject IRacketService RacketService
@inject IBallService BallService

@{
    var requestCulture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "en";
    var isBg = currentCulture == "bg";

    ViewData["Title"] = isBg ? "Начало" : "Home";

    var rackets = await RacketService.GetAllRacketsAsync();
    var topRacket = rackets.OrderByDescending(r => r.Price).FirstOrDefault();

    var balls = await BallService.GetAllBallsAsync();
    var totalBallStock = balls.Sum(b => b.Quantity);
}

<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

<div class="home-container pb-5">
    <div class="hero-section text-center">
        <div class="zigzag-wrapper">
            <svg class="zigzag-line" viewBox="0 0 1000 100" preserveAspectRatio="none">
                <polyline points="0,50 40,10 80,90 120,10 160,90 200,10 240,90 280,10 320,90 360,10 400,90 440,10 480,90 520,10 560,90 600,10 640,90 680,10 720,90 760,10 800,90 840,10 880,90 920,10 960,90 1000,50" />
            </svg>
        </div>

        <div class="container" style="position: relative; z-index: 1;">
            <span class="badge bg-dark border border-secondary border-opacity-25 text-white-50 px-3 py-2 rounded-pill mb-4 tracking-wider small shadow">
                <i class="bi bi-circle-fill text-accent me-2" style="font-size: 0.5rem; vertical-align: middle;"></i>
                @(isBg ? "ТЕНИС АКАДЕМИЯ ОТ НОВО ПОКОЛЕНИЕ" : "NEXT-GEN TENNIS ACADEMY")
            </span>

            <h1 class="hero-title mb-4">
                @(isBg ? "Доминирай на" : "Dominate the") <br />
                <span>@(isBg ? "Корта" : "Court")</span>
            </h1>

            <p class="hero-subtitle mb-4">
                @(isBg ? "Резервирай корт за секунди, екипирай се с най-доброто и вдигни нивото на играта си." : "Book a court in seconds, gear up with the best, and elevate your game.")
            </p>

            <div class="working-hours-wrapper">
                <svg class="oval-svg" viewBox="0 0 320 56">
                    <rect x="2" y="2" width="316" height="52" rx="26" ry="26" class="oval-path" />
                </svg>
                <div class="working-hours-text">
                    <i class="bi bi-clock-history me-2 text-accent"></i>
                    @(isBg ? "Работно време: 08:00 - 20:00" : "Working Hours: 08:00 - 20:00")
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Reservation" asp-action="Index" class="btn btn-hero-primary text-decoration-none">
                    <i class="bi bi-calendar2-check-fill me-2"></i>@(isBg ? "Резервирай Корт" : "Book a Court")
                </a>
                <a asp-controller="Racket" asp-action="Index" class="btn btn-hero-outline text-decoration-none">
                    <i class="bi bi-shop me-2"></i>@(isBg ? "Към Магазина" : "To the Shop")
                </a>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="bento-grid">
            <a asp-controller="Reservation" asp-action="Index" class="bento-card bento-large text-decoration-none">
                <div class="bento-glow glow-bl"></div>
                <div class="bento-content h-100 d-flex flex-column justify-content-between">
                    <i class="bi bi-calendar-event bento-icon"></i>
                    <div>
                        <h2 class="display-6 fw-bold text-white mb-3">@(isBg ? "Твоят корт те очаква." : "Your court awaits.")</h2>
                        <p class="text-white-50 fs-5 mb-0">
                            @(isBg ? "Провери графика в реално време и запази своя час с няколко клика. Играй без забавяне." : "Check the real-time schedule and secure your slot with a few clicks. Play without delay.")
                        </p>
                    </div>
                    <div class="mt-4">
                        <span class="text-accent fw-bold tracking-wider text-uppercase small">@(isBg ? "Запази сега" : "Book Now") <i class="bi bi-arrow-right ms-1"></i></span>
                    </div>
                </div>
            </a>

            <a asp-controller="Racket" asp-action="Index" class="bento-card bento-small text-decoration-none">
                <div class="bento-glow glow-tr"></div>
                <div class="bento-content h-100 d-flex flex-column justify-content-between">
                    <i class="bi bi-lightning-charge-fill bento-icon"></i>
                    <div>
                        <span class="text-muted small text-uppercase d-block mb-1">@(isBg ? "Премиум избор" : "Premium Choice")</span>
                        @if (topRacket != null)
                        {
                            <h4 class="fw-bold text-white m-0">@topRacket.Brand</h4>
                            <p class="text-accent fw-semibold mb-3">@topRacket.Model</p>
                            <p class="text-white-50 small">@(isBg ? "Вземи професионална екипировка на топ цена." : "Get pro equipment at the best price.")</p>
                        }
                        else
                        {
                            <h3 class="fw-bold text-white mb-2">@(isBg ? "Про Ракети" : "Pro Rackets")</h3>
                            <p class="text-white-50">@(isBg ? "Разгледай професионалните ни модели." : "Browse our pro models.")</p>
                        }
                    </div>
                    <div>
                        <span class="text-accent fw-bold tracking-wider text-uppercase small">@(isBg ? "Виж модела" : "View Gear") <i class="bi bi-arrow-right ms-1"></i></span>
                    </div>
                </div>
            </a>

            <a asp-controller="Ball" asp-action="Index" class="bento-card bento-small text-decoration-none">
                <div class="bento-glow glow-bl"></div>
                <div class="bento-content h-100 d-flex flex-column justify-content-between">
                    <i class="bi bi-record-circle-fill bento-icon"></i>
                    <div>
                        <h3 class="fw-bold text-white mb-2">@(isBg ? "Аксесоари" : "Accessories")</h3>
                        <p class="text-white-50 mb-3">@(isBg ? "Топки, чанти и всичко нужно за мача." : "Balls, bags, and everything needed for the match.")</p>

                        <div class="badge bg-dark border border-secondary border-opacity-25 px-3 py-2 rounded-3 text-start w-100">
                            <span class="text-white-50 small d-block">@(isBg ? "Общо топки на склад:" : "Total balls in stock:")</span>
                            <span class="text-success fw-bold fs-5">@totalBallStock @(isBg ? "бр." : "pcs")</span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="text-accent fw-bold tracking-wider text-uppercase small">@(isBg ? "Към магазина" : "Shop Now") <i class="bi bi-arrow-right ms-1"></i></span>
                    </div>
                </div>
            </a>

            <div class="bento-card bento-quote text-decoration-none" onclick="toggleScroll(this)" style="cursor: pointer;">
                <div class="bento-glow glow-tr"></div>
                <div class="cyber-scroll-container w-100 h-100 d-flex align-items-center justify-content-center position-relative">
                    <div class="click-hint position-absolute d-flex align-items-center gap-2">
                        <i class="bi bi-hand-index-thumb fs-4"></i>
                        <span class="fw-bold tracking-wider text-uppercase small">
                            @(isBg ? "Кликни за цитат" : "Click for a quote")
                        </span>
                    </div>
                    <div class="cyber-scroll-rod"></div>
                    <div class="cyber-scroll-paper">
                        <div class="quote-content">
                            <i class="bi bi-quote fs-2 text-accent opacity-50"></i>
                            <h5 id="quote-text" class="fw-light text-white mt-1 mb-0" style="font-style: italic;"></h5>
                        </div>
                    </div>
                    <div class="cyber-scroll-rod"></div>
                </div>
            </div>

            <div class="bento-card bento-wide">
                <div class="bento-glow glow-tr"></div>
                <div class="bento-content w-100 d-flex flex-column flex-lg-row align-items-center justify-content-between">
                    <div class="text-center text-lg-start mb-4 mb-lg-0">
                        <h2 class="fw-bold text-white mb-1">@(isBg ? "Готов ли си за игра?" : "Ready to play?")</h2>
                        <p class="text-white-50 m-0">@(isBg ? "Присъедини се към стотици активни играчи." : "Join hundreds of active players.")</p>
                    </div>

                    <div class="d-flex gap-4 gap-md-5 text-center">
                        <div>
                            <h2 class="text-accent fw-black mb-0 display-5 fw-bold">6+</h2>
                            <span class="text-white-50 small text-uppercase tracking-wider">@(isBg ? "Премиум Корта" : "Premium Courts")</span>
                        </div>
                        <div>
                            <h2 class="text-accent fw-black mb-0 display-5 fw-bold">24/7</h2>
                            <span class="text-white-50 small text-uppercase tracking-wider">@(isBg ? "Резервации" : "Booking")</span>
                        </div>
                        <div>
                            <h2 class="text-accent fw-black mb-0 display-5 fw-bold">100%</h2>
                            <span class="text-white-50 small text-uppercase tracking-wider">@(isBg ? "Оригинална Екипировка" : "Authentic Gear")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleScroll(card) {
        const isOpen = card.classList.contains('is-open');
        const isBg = "@isBg" === "True";

        const quotes = isBg ? [
            "Трудното побеждава таланта, когато талантът не работи здраво.",
            "Не можеш да сложиш лимит на нищо. Колкото повече мечтаеш, толкова по-далеч стигаш.",
            "Печеля или губя, винаги научавам нещо.",
            "Шампионите продължават да играят, докато не го направят както трябва.",
            "Няма невъзможни неща, просто някои отнемат повече време.",
            "Успехът не е окончателен, провалът не е фатален: важна е смелостта да продължиш."
        ] : [
            "Hard work beats talent when talent doesn't work hard.",
            "You can't put a limit on anything. The more you dream, the farther you get.",
            "Win or lose, I always learn something.",
            "Champions keep playing until they get it right.",
            "It never gets easier, you just get stronger.",
            "Success is not final, failure is not fatal: it is the courage to continue that counts."
        ];

        if (!isOpen) {
            const randomText = quotes[Math.floor(Math.random() * quotes.length)];
            document.getElementById('quote-text').innerText = randomText;

            card.classList.add('is-open');
        } else {
            card.classList.remove('is-open');
        }
    }
</script>