@using static TennisAcademyApp.GCommon.Validations.ValidationConstants.Reservation;
@using TennisAcademyApp.ViewModels.Reservation;
@model TennisAcademyApp.ViewModels.Reservation.ReservationDetailsViewModel

@{
    var requestCulture = ViewContext.HttpContext.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "en";
    var isBg = currentCulture == "bg";

    ViewData["Title"] = isBg ? "Детайли за резервацията" : "Reservation Details";
}

<div class="container mt-4">
    <h2 class="text-center mb-4 fw-semibold">@(isBg ? "Детайли за резервацията" : "Reservation Details")</h2>

    <div class="card bg-card border-0 shadow-lg rounded-4 overflow-hidden mb-5">
        <div class="row g-0">
            <div class="col-md-5">
                <img src="@Url.Content(Model.ImageUrl)"
                     class="img-fluid w-100 h-100 object-fit-cover"
                     style="max-height: 350px; min-height: 100%;"
                     alt="Surface Image" />
            </div>

            <div class="col-md-7">
                <div class="card-body p-4 d-flex flex-column justify-content-between h-100">
                    <div>
                        <h4 class="card-title mb-4 text-primary fw-bold">
                            @if (isBg)
                            {
                                <text>@Model.TrainingTypeName с @Model.CoachName</text>
                            }
                            else
                            {
                                <text>@Model.TrainingTypeName with @Model.CoachName</text>
                            }
                        </h4>

                        <hr class="border-secondary opacity-25 mb-4" />

                        <div class="d-flex flex-column gap-3 fs-5">
                            <div>
                                <i class="bi bi-calendar3 text-primary me-2"></i>
                                <strong>@(isBg ? "Дата и час:" : "Date & Time:")</strong>
                                <span class="text-light">@Model.Date.ToString(DateFormat)</span>
                            </div>

                            <div>
                                <i class="bi bi-hourglass-split text-primary me-2"></i>
                                <strong>@(isBg ? "Продължителност:" : "Duration:")</strong>
                                <span class="text-light">@Model.Duration @(isBg ? "минути" : "minutes")</span>
                            </div>

                            <div>
                                <i class="bi bi-layers-half text-primary me-2"></i>
                                <strong>@(isBg ? "Настилка:" : "Surface:")</strong>
                                <span class="text-light">@Model.SurfaceName</span>
                            </div>

                            @if (isBg && !string.IsNullOrWhiteSpace(Model.NoteBg))
                            {
                                <div>
                                    <i class="bi bi-sticky text-primary me-2"></i>
                                    <strong>@(isBg ? "Бележка:" : "Note:")</strong>
                                    <span class="text-muted d-block small mt-1 ps-4">@Model.NoteBg</span>
                                </div>
                            }
                            else if (!string.IsNullOrWhiteSpace(Model.Note))
                            {
                                <div>
                                    <i class="bi bi-sticky text-primary me-2"></i>
                                    <strong>@(isBg ? "Бележка:" : "Note:")</strong>
                                    <span class="text-muted d-block small mt-1 ps-4">@Model.Note</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-3">
                        <a asp-action="Index" class="btn btn-outline-primary px-4 py-2 rounded-3">
                            <i class="bi bi-arrow-left me-2"></i>@(isBg ? "Назад" : "Back")
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-4 py-2 rounded-3 fw-semibold">
                            <i class="bi bi-trash3 me-2"></i>@(isBg ? "Изтрий" : "Delete")
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>